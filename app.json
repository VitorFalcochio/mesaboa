{
  "expo": {
    "name": "Bocado Rio Preto",
    "slug": "bocado-rio-preto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./Designer/Logos/2.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFF8EE",
    "scheme": "bocado",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mesaboa.riopreto",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mesaboa.riopreto",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./Designer/Logos/2.png",
        "backgroundColor": "#06140f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
